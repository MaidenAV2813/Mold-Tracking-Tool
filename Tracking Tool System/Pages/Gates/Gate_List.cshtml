@page
@model Tracking_Tool_System.Pages.Gates.Gates_ListModel
@{
	ViewData["Title"] = "Gates";
}

<section class="content-header">
    <div class="container-fluid">
        <h1>Gates</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Lista de Gates</h3>
                <div class="card-tools">
                    <a asp-page="/Gates/CreateGate" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> Agregar nuevo Gate
                    </a>
                    <a id="editBtn" class="btn btn-warning btn-sm disabled">
                        <i class="fas fa-edit"></i> Editar Gate
                    </a>
                </div>
            </div>

            <div class="card-body">

                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Gate</th>
                            <th>Fecha de creación</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var Gates in Model.GridList)
                        {
                            <tr onclick="selectRow(@Gates.GateID)" style="cursor:pointer;">
                                <td>@Gates.GateType</td>
                                <td>@Gates.DateCreation?.ToString("MM-dd-yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>     
    </div>
</section>

<script>
    @* Remarca la linea seleccionada en la lista a modificar de Gates*@
       function selectRow(id) {

           document.querySelectorAll("tbody tr").forEach(r => r.classList.remove("table-primary"));

           event.currentTarget.classList.add("table-primary");

           let editBtn = document.getElementById("editBtn");

           editBtn.classList.remove("disabled");
           editBtn.href = "/Gates/Edit?id=" + id;
       }
</script>