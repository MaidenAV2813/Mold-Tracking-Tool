@page
@model Tracking_Tool_System.Pages.Rol.CreateModel

@{
    ViewData["Title"] = "Crear Rol"; 
}

        <section class="content-header">
            <div class="container-fluid">
                <h1>Crear Rol</h1>
            </div>
        </section>

        <section class="content">
            <div class="container-fluid">

                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Información del rol</h3>
                    </div>

                    <form method="post">
                        <div class="card-body">

                            <div asp-validation-summary="All" class="text-danger"></div>

                            <div class="form-group">
                                <label>Descripción</label>
                                <input asp-for="RolDescription" class="form-control" placeholder="Ingrese la descripción del rol" />
                            </div>

                            <div class="form-group">
                                <label>Tipo</label>
                                <input asp-for="RolType" class="form-control" placeholder="Ingrese el tipo de rol" />
                            </div>

                            <div class="form-group">
                                <label>Estado</label>
                                <select asp-for="Status" class="form-control">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>

                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a asp-page="/Rol/Rol_List" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>

            </div>
        </section>
