@page
@model Tracking_Tool_System.Pages.User.User_ListModel

<div class="card">
    <div class="card-header">
        <h3 class="card-title">User List</h3>
        <div class="card-tools">
            <a asp-page="/User/Create" class="btn btn-primary btn-sm">New User</a>
        </div>
    </div>

    <div class="card-body">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>                 
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Fecha de Creación</th>

                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.IdNumber</td>
                        <td>@user.EmpName</td>
                        <td>@user.RolDescription</td>
                        <td>@(user.UserStatus == true ? "Active" : "Inactive")</td>
                        <td>@(user.DateCreation?.ToString("yyyy-MM-dd") ?? "")</td>
@*                         <td>
                            <a asp-page="/User/Edit" asp-route-id="@user.IdNumber" class="btn btn-warning btn-sm">
                                Edit
                            </a>
                        </td> *@
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
