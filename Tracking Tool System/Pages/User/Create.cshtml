@page
@model Tracking_Tool_System.Pages.User.CreateModel

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Crear Usuario</h3>
    </div>

    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label># Gafete</label>
                <input asp-for="IdNumber" class="form-control" />
            </div>

            <div class="form-group">
                <label>Nombre</label>
                <input asp-for="EmpName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Rol</label>

                <select asp-for="RolID" class="form-control">
                    <option value="">Seleccione un Rol</option>

                    @foreach (var rol in Model.Roles)
                    {
                        <option value="@rol.RolID">
                            @rol.RolDescription
                        </option>
                    }
                </select>
            </div>

            <div class="form-check">
                <input asp-for="UserStatus" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <br />

            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-page="/User/User_List" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
