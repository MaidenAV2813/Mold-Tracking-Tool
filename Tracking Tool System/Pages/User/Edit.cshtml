@page
@model Tracking_Tool_System.Pages.User.EditModel

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Edit User</h3>
    </div>

    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="UserID" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label>Rol ID</label>
                <input asp-for="RolID" class="form-control" />
            </div>

            <div class="form-group">
                <label>Username</label>
                <input asp-for="Username" class="form-control" />
            </div>

            <div class="form-group">
                <label>ID Number</label>
                <input asp-for="IdNumber" class="form-control" />
            </div>

            <div class="form-group">
                <label>Name</label>
                <input asp-for="EmpName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Rol</label>
                <input asp-for="Rol" class="form-control" />
            </div>

            <div class="form-check">
                <input asp-for="UserStatus" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <br />

            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-page="/User/User_List" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
