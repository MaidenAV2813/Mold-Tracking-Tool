@page
@model Tracking_Tool_System.Pages.Access.EditAccessModel

@{
    ViewData["Title"] = "Editar Accesos del Rol";
}

<section class="content-header">
    <div class="container-fluid">
        <h1>Editar Accesos del Rol</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="card card-warning">

            <div class="card-header">
                <h3 class="card-title">Configuración de accesos</h3>
            </div>

            <form method="post">

                <div class="card-body">

                    <input type="hidden" asp-for="RolID" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label>Tipo de Rol</label>

                        <select asp-for="RolID"
                                class="form-control"
                                disabled>

                            @foreach (var rol in Model.Roles)
                            {
                                <option value="@rol.RolID">
                                    @rol.RolType
                                </option>
                            }

                        </select>
                    </div>

                    <div class="form-group">
                        <label>Módulos del Rol</label>

                        <select asp-for="SelectedModules"
                                class="duallistbox"
                                multiple="multiple">

                            @foreach (var module in Model.Modules)
                            {
                                if (Model.SelectedModules.Contains(module))
                                {
                                    <option value="@module" selected>
                                        @module
                                    </option>
                                }
                                else
                                {
                                    <option value="@module">
                                        @module
                                    </option>
                                }
                            }

                        </select>
                    </div>

                </div>

                <div class="card-footer">

                    <button type="submit"
                            class="btn btn-warning">
                        Actualizar
                    </button>

                    <a asp-page="/Access/Access_List"
                           class="btn btn-secondary">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            $('.duallistbox').bootstrapDualListbox({
                nonSelectedListLabel: 'Módulos disponibles',
                selectedListLabel: 'Módulos asignados al rol',
                moveOnSelect: false,
                filterTextClear: 'Mostrar todos',
                filterPlaceHolder: 'Buscar',
                infoText: 'Mostrando {0}',
                infoTextEmpty: 'Lista vacía'
            });
        });
    </script>
}