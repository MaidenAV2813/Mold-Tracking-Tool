@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    string versionText = Configuration["Version"];
}
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Mold Tracking Tool</title>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
        <link rel="stylesheet" href="~/Template/plugins/fontawesome-free/css/all.min.css">
        <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
        <link rel="stylesheet" href="~/Template/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
        <link rel="stylesheet" href="~/Template/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
        <link rel="stylesheet" href="~/Template/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
        <link rel="stylesheet" href="~/Template/plugins/daterangepicker/daterangepicker.css">
        <link rel="stylesheet" href="~/Template/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
        <link rel="stylesheet" href="~/Template/plugins/bootstrap-colorpicker/css/bootstrap-colorpicker.min.css">
        <link rel="stylesheet" href="~/Template/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
        <link rel="stylesheet" href="~/Template/plugins/select2/css/select2.min.css">
        <link rel="stylesheet" href="~/Template/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css">
        <link rel="stylesheet" href="~/Template/plugins/bootstrap4-duallistbox/bootstrap-duallistbox.min.css">
        <link rel="stylesheet" href="~/Template/plugins/bs-stepper/css/bs-stepper.min.css">
        <link rel="stylesheet" href="~/Template/plugins/dropzone/min/dropzone.min.css">
        <link rel="stylesheet" href="~/Template/dist/css/adminlte.min.css">
 
        <style>
            body.hold-transition {
                background: linear-gradient(135deg, #1E3A5F, #20124d);
            }
        </style>
 
        @await RenderSectionAsync("styles", required: false)
    </head>
    <body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
        @RenderBody()
        <div class="wrapper">
        <footer class="main-footer" style ="background-color: slategrey; color: white; text-align: center; padding: 10px 0; width: 100%; margin: 0;">
                <small>
                    © Mold Tracking Tool Version @versionText <br> Designed By ICU Medical Applications Support Costa Rica
                </small>
            </footer>
        </div>
        @await RenderSectionAsync("Scripts", required: false)

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="~/js/scripts.js"></script>
    </body>
</html>

